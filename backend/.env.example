# =========================================================================
# Market 数据采集中心后端环境变量示例
# 复制为 .env 后按需修改；生产环境请勿提交真实密钥到仓库。
# =========================================================================

# ---- Database ----
# 默认 SQLite（本机零依赖开发模式），生产环境改为 PostgreSQL：
#   postgresql+asyncpg://postgres:postgres@localhost:5432/platform
DATABASE_URL=sqlite+aiosqlite:///./market.db
# 业务表所在 schema（仅 PostgreSQL 生效，SQLite 模式下自动忽略）。
DATABASE_SCHEMA=marketing

# ---- Public deployment ----
# 公网发布时填写真实域名和证书通知邮箱；本地开发可以留空。
MARKET_DOMAIN=
ACME_EMAIL=

# ---- LLM (DeepSeek OpenAI 兼容接口) ----
# 在 https://platform.deepseek.com 申请 API Key 后填入。
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ---- 钉钉机器人 ----
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# ---- 鉴权 ----
JWT_SECRET_KEY=replace-with-at-least-32-random-characters
SECRET_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
AUTH_COOKIE_NAME=market_session
# 生产 HTTPS 部署建议设为 true；本机 HTTP 开发可为 false。
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=strict
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-initial-password

# ---- 内网上传 API Key（RPA / 爬虫推送鉴权） ----
UPLOAD_API_KEY=replace-with-a-strong-upload-key

# ---- CORS ----
# JSON 数组形式，允许的前端来源。
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:8002"]
