# Market 数据采集中心部署环境变量示例。
# 复制为 .env 后填写真实值；不要提交真实密钥。

POSTGRES_DB=market
POSTGRES_USER=market
POSTGRES_PASSWORD=replace-with-a-strong-db-password
DATABASE_SCHEMA=marketing

# 公网发布时必须填写真实域名和证书通知邮箱。
# 只填域名，不要带 http:// 或 https://。
MARKET_DOMAIN=market.example.cn
ACME_EMAIL=ops@example.cn

JWT_SECRET_KEY=replace-with-at-least-32-random-characters
SECRET_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-initial-password
UPLOAD_API_KEY=replace-with-a-strong-upload-key
AUTH_COOKIE_NAME=market_session
# 本地 docker compose 走 HTTP，保持 false；生产 HTTPS 入口请改为 true。
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=strict

# 本地部署可使用 HTTP 来源；公网 HTTPS 发布时改为 ["https://你的域名"]。
CORS_ORIGINS=["http://localhost:3000","http://localhost"]
