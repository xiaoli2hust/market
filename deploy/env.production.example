# =========================================================================
# Market 数据采集中心生产环境配置
# 复制到项目根目录 .env 后填写。不要提交真实 .env。
# =========================================================================

COMPOSE_PROJECT_NAME=market

# ---- Public entry ----
# 示例：market.example.com；必须是公网可解析到本机的域名。
MARKET_DOMAIN=market.example.com
ACME_EMAIL=ops@example.com

# ---- Database ----
POSTGRES_DB=market
POSTGRES_USER=market
POSTGRES_PASSWORD=replace-with-a-strong-db-password
DATABASE_SCHEMA=marketing

# ---- Security ----
JWT_SECRET_KEY=replace-with-at-least-32-random-characters
SECRET_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-initial-password
UPLOAD_API_KEY=replace-with-a-strong-upload-key

# Public HTTPS must keep secure cookie enabled.
AUTH_COOKIE_NAME=market_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=strict

# Must include your public HTTPS origin. Do not use *.
CORS_ORIGINS=["https://market.example.com"]
